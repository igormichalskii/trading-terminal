{
  "$schema": "https://example.com/schemas/indicator-registry.v1.json",
  "version": "1.0.0",
  "description": "Registry of price-chart overlay indicators (share Y-axis with price).",
  "fieldDefinitions": {
    "id": "Stable, lowercase, snake_case unique identifier.",
    "name": "Human-readable display name.",
    "category": "Top-level grouping for UI menus.",
    "subcategory": "Optional finer grouping within a category.",
    "overlay": "Always true in this registry; kept for forward-compat with non-overlay indicators.",
    "renderType": "How the indicator draws on the chart: line | multi_line | band | channel | cloud | dots | shapes | levels | ladder | candles | bricks | zones | profile | fan | pitchfork | zigzag",
    "inputs": "Array of parameter definitions: { key, label, type, default, min?, max?, options? }.",
    "outputs": "Array of plotted series: { key, label, style? }.",
    "sources": "Allowed price source inputs: open | high | low | close | hl2 | hlc3 | ohlc4 | volume.",
    "notes": "Implementation caveats, edge cases, or platform conventions."
  },
  "categories": [
    {
      "id": "moving_averages",
      "label": "Moving Averages",
      "indicators": [
        {
          "id": "sma",
          "name": "Simple Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "sma", "label": "SMA" }]
        },
        {
          "id": "ema",
          "name": "Exponential Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "ema", "label": "EMA" }]
        },
        {
          "id": "wma",
          "name": "Weighted Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "wma", "label": "WMA" }]
        },
        {
          "id": "hma",
          "name": "Hull Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 16, "min": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "hma", "label": "HMA" }]
        },
        {
          "id": "vwma",
          "name": "Volume Weighted Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "vwma", "label": "VWMA" }],
          "notes": "Requires volume data; degrades to SMA if volume is unavailable."
        },
        {
          "id": "dema",
          "name": "Double Exponential Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "dema", "label": "DEMA" }]
        },
        {
          "id": "tema",
          "name": "Triple Exponential Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "tema", "label": "TEMA" }]
        },
        {
          "id": "kama",
          "name": "Kaufman Adaptive Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Efficiency Length", "type": "int", "default": 10, "min": 2 },
            { "key": "fastLength", "label": "Fast EMA", "type": "int", "default": 2, "min": 1 },
            { "key": "slowLength", "label": "Slow EMA", "type": "int", "default": 30, "min": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "kama", "label": "KAMA" }]
        },
        {
          "id": "alma",
          "name": "Arnaud Legoux Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 9, "min": 2 },
            { "key": "offset", "label": "Offset", "type": "float", "default": 0.85, "min": 0, "max": 1 },
            { "key": "sigma", "label": "Sigma", "type": "float", "default": 6, "min": 0.1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "alma", "label": "ALMA" }]
        },
        {
          "id": "zlema",
          "name": "Zero Lag Exponential Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "zlema", "label": "ZLEMA" }]
        },
        {
          "id": "lsma",
          "name": "Least Squares Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 25, "min": 2 },
            { "key": "offset", "label": "Offset", "type": "int", "default": 0 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "lsma", "label": "LSMA" }],
          "notes": "Also known as Linear Regression Curve."
        },
        {
          "id": "trima",
          "name": "Triangular Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "trima", "label": "TRIMA" }]
        },
        {
          "id": "t3",
          "name": "Tillson T3",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 8, "min": 2 },
            { "key": "volumeFactor", "label": "Volume Factor", "type": "float", "default": 0.7, "min": 0, "max": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "t3", "label": "T3" }]
        },
        {
          "id": "mcginley",
          "name": "McGinley Dynamic",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 14, "min": 1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "mcginley", "label": "McGinley" }]
        },
        {
          "id": "vidya",
          "name": "Variable Index Dynamic Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 9, "min": 2 },
            { "key": "histLength", "label": "History Length", "type": "int", "default": 30, "min": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "vidya", "label": "VIDYA" }]
        },
        {
          "id": "frama",
          "name": "Fractal Adaptive Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 16, "min": 4 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "frama", "label": "FRAMA" }],
          "notes": "Length should be even."
        },
        {
          "id": "jma",
          "name": "Jurik Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 14, "min": 2 },
            { "key": "phase", "label": "Phase", "type": "float", "default": 50, "min": -100, "max": 100 },
            { "key": "power", "label": "Power", "type": "float", "default": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "jma", "label": "JMA" }]
        },
        {
          "id": "gmma",
          "name": "Guppy Multiple Moving Average",
          "renderType": "multi_line",
          "inputs": [
            { "key": "shortLengths", "label": "Short EMAs", "type": "intArray", "default": [3, 5, 8, 10, 12, 15] },
            { "key": "longLengths", "label": "Long EMAs", "type": "intArray", "default": [30, 35, 40, 45, 50, 60] },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [
            { "key": "short", "label": "Short Group" },
            { "key": "long", "label": "Long Group" }
          ]
        },
        {
          "id": "dma",
          "name": "Displaced Moving Average",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 1 },
            { "key": "displacement", "label": "Displacement", "type": "int", "default": 5 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "dma", "label": "DMA" }]
        }
      ]
    },
    {
      "id": "volume_anchored",
      "label": "Volume-Anchored",
      "indicators": [
        {
          "id": "vwap",
          "name": "VWAP",
          "renderType": "line",
          "inputs": [
            { "key": "anchor", "label": "Anchor", "type": "enum", "default": "session",
              "options": ["session", "week", "month", "quarter", "year", "earnings"] },
            { "key": "showBands", "label": "Show Std Dev Bands", "type": "bool", "default": false },
            { "key": "bandMultipliers", "label": "Band Multipliers", "type": "floatArray", "default": [1, 2, 3] }
          ],
          "outputs": [
            { "key": "vwap", "label": "VWAP" },
            { "key": "upperBands", "label": "Upper Bands" },
            { "key": "lowerBands", "label": "Lower Bands" }
          ],
          "notes": "Requires volume; resets at the chosen anchor boundary."
        },
        {
          "id": "anchored_vwap",
          "name": "Anchored VWAP",
          "renderType": "line",
          "inputs": [
            { "key": "anchorTime", "label": "Anchor Time", "type": "datetime", "default": null }
          ],
          "outputs": [{ "key": "avwap", "label": "AVWAP" }],
          "notes": "User-placed anchor; supports multiple instances per chart."
        }
      ]
    },
    {
      "id": "bands_channels",
      "label": "Bands & Channels",
      "indicators": [
        {
          "id": "bollinger_bands",
          "name": "Bollinger Bands",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 },
            { "key": "stdDev", "label": "Std Deviations", "type": "float", "default": 2, "min": 0.1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" },
            { "key": "maType", "label": "Basis MA Type", "type": "enum", "default": "sma", "options": ["sma", "ema", "wma", "vwma"] }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper Band" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower Band" }
          ]
        },
        {
          "id": "keltner_channels",
          "name": "Keltner Channels",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 },
            { "key": "atrLength", "label": "ATR Length", "type": "int", "default": 10, "min": 1 },
            { "key": "multiplier", "label": "Multiplier", "type": "float", "default": 2, "min": 0.1 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "donchian_channels",
          "name": "Donchian Channels",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "price_channel",
          "name": "Price Channel",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "envelope",
          "name": "Envelope",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 },
            { "key": "percent", "label": "Percent", "type": "float", "default": 5, "min": 0.01 },
            { "key": "maType", "label": "MA Type", "type": "enum", "default": "sma", "options": ["sma", "ema", "wma"] }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "starc_bands",
          "name": "STARC Bands",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "MA Length", "type": "int", "default": 5, "min": 2 },
            { "key": "atrLength", "label": "ATR Length", "type": "int", "default": 15, "min": 1 },
            { "key": "multiplier", "label": "Multiplier", "type": "float", "default": 2, "min": 0.1 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "acceleration_bands",
          "name": "Acceleration Bands",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 20, "min": 2 },
            { "key": "factor", "label": "Factor", "type": "float", "default": 0.001 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "linear_regression_channel",
          "name": "Linear Regression Channel",
          "renderType": "channel",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 100, "min": 2 },
            { "key": "deviations", "label": "Deviations", "type": "float", "default": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Regression Line" },
            { "key": "lower", "label": "Lower" }
          ]
        },
        {
          "id": "standard_error_bands",
          "name": "Standard Error Bands",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 21, "min": 2 },
            { "key": "errors", "label": "Errors", "type": "float", "default": 2 },
            { "key": "smoothLength", "label": "Smoothing", "type": "int", "default": 3 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "basis", "label": "Basis" },
            { "key": "lower", "label": "Lower" }
          ]
        }
      ]
    },
    {
      "id": "trend_momentum",
      "label": "Trend & Momentum",
      "indicators": [
        {
          "id": "parabolic_sar",
          "name": "Parabolic SAR",
          "renderType": "dots",
          "inputs": [
            { "key": "step", "label": "Start", "type": "float", "default": 0.02, "min": 0.001 },
            { "key": "increment", "label": "Increment", "type": "float", "default": 0.02 },
            { "key": "maximum", "label": "Maximum", "type": "float", "default": 0.2 }
          ],
          "outputs": [{ "key": "sar", "label": "SAR" }]
        },
        {
          "id": "supertrend",
          "name": "SuperTrend",
          "renderType": "line",
          "inputs": [
            { "key": "atrLength", "label": "ATR Length", "type": "int", "default": 10, "min": 1 },
            { "key": "multiplier", "label": "Multiplier", "type": "float", "default": 3, "min": 0.1 }
          ],
          "outputs": [
            { "key": "supertrend", "label": "SuperTrend" },
            { "key": "direction", "label": "Direction", "style": "hidden" }
          ]
        },
        {
          "id": "ichimoku",
          "name": "Ichimoku Kinko Hyo",
          "renderType": "cloud",
          "inputs": [
            { "key": "tenkanLength", "label": "Tenkan", "type": "int", "default": 9, "min": 1 },
            { "key": "kijunLength", "label": "Kijun", "type": "int", "default": 26, "min": 1 },
            { "key": "senkouBLength", "label": "Senkou B", "type": "int", "default": 52, "min": 1 },
            { "key": "displacement", "label": "Displacement", "type": "int", "default": 26 }
          ],
          "outputs": [
            { "key": "tenkan", "label": "Tenkan-sen" },
            { "key": "kijun", "label": "Kijun-sen" },
            { "key": "senkouA", "label": "Senkou A" },
            { "key": "senkouB", "label": "Senkou B" },
            { "key": "chikou", "label": "Chikou" },
            { "key": "kumo", "label": "Kumo (Cloud)" }
          ]
        },
        {
          "id": "zigzag",
          "name": "ZigZag",
          "renderType": "zigzag",
          "inputs": [
            { "key": "deviation", "label": "Deviation %", "type": "float", "default": 5, "min": 0.1 },
            { "key": "depth", "label": "Depth", "type": "int", "default": 10, "min": 2 }
          ],
          "outputs": [{ "key": "zigzag", "label": "ZigZag" }]
        },
        {
          "id": "heikin_ashi",
          "name": "Heikin Ashi",
          "renderType": "candles",
          "inputs": [],
          "outputs": [{ "key": "ha", "label": "HA Candles" }],
          "notes": "Alternative candle calculation; commonly exposed as a chart-type toggle rather than a standard indicator."
        },
        {
          "id": "renko",
          "name": "Renko",
          "renderType": "bricks",
          "inputs": [
            { "key": "boxSize", "label": "Box Size", "type": "float", "default": null },
            { "key": "boxSizeMethod", "label": "Method", "type": "enum", "default": "atr", "options": ["atr", "fixed", "percent"] },
            { "key": "atrLength", "label": "ATR Length", "type": "int", "default": 14 }
          ],
          "outputs": [{ "key": "renko", "label": "Renko" }],
          "notes": "Alternative chart type; X-axis is no longer time-uniform."
        },
        {
          "id": "linear_regression_line",
          "name": "Linear Regression Line",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 100, "min": 2 },
            { "key": "source", "label": "Source", "type": "source", "default": "close" }
          ],
          "outputs": [{ "key": "lr", "label": "Linear Regression" }]
        },
        {
          "id": "auto_trendlines",
          "name": "Auto Trend Lines",
          "renderType": "shapes",
          "inputs": [
            { "key": "lookback", "label": "Lookback", "type": "int", "default": 100, "min": 10 },
            { "key": "minPivots", "label": "Min Pivots", "type": "int", "default": 2 }
          ],
          "outputs": [{ "key": "trendlines", "label": "Trend Lines" }]
        },
        {
          "id": "andrews_pitchfork",
          "name": "Andrews' Pitchfork",
          "renderType": "pitchfork",
          "inputs": [
            { "key": "p1", "label": "Pivot 1", "type": "point" },
            { "key": "p2", "label": "Pivot 2", "type": "point" },
            { "key": "p3", "label": "Pivot 3", "type": "point" },
            { "key": "variant", "label": "Variant", "type": "enum", "default": "standard", "options": ["standard", "schiff", "modified_schiff"] }
          ],
          "outputs": [{ "key": "pitchfork", "label": "Pitchfork" }],
          "notes": "Typically a drawing tool with auto-detection variants."
        },
        {
          "id": "chandelier_exit",
          "name": "Chandelier Exit",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 22, "min": 1 },
            { "key": "atrMultiplier", "label": "ATR Multiplier", "type": "float", "default": 3 }
          ],
          "outputs": [
            { "key": "long", "label": "Long Stop" },
            { "key": "short", "label": "Short Stop" }
          ]
        },
        {
          "id": "atr_trailing_stop",
          "name": "ATR Trailing Stop",
          "renderType": "line",
          "inputs": [
            { "key": "atrLength", "label": "ATR Length", "type": "int", "default": 14, "min": 1 },
            { "key": "multiplier", "label": "Multiplier", "type": "float", "default": 3 }
          ],
          "outputs": [{ "key": "stop", "label": "Trailing Stop" }]
        },
        {
          "id": "hilo_activator",
          "name": "HiLo Activator",
          "renderType": "line",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 3, "min": 1 }
          ],
          "outputs": [{ "key": "hilo", "label": "HiLo" }]
        },
        {
          "id": "vortex_bands",
          "name": "Vortex Bands",
          "renderType": "band",
          "inputs": [
            { "key": "length", "label": "Length", "type": "int", "default": 14 },
            { "key": "multiplier", "label": "Multiplier", "type": "float", "default": 2 }
          ],
          "outputs": [
            { "key": "upper", "label": "Upper" },
            { "key": "lower", "label": "Lower" }
          ]
        }
      ]
    },
    {
      "id": "pivots_sr",
      "label": "Pivots & Support/Resistance",
      "indicators": [
        {
          "id": "pivot_points_standard",
          "name": "Pivot Points (Standard)",
          "renderType": "levels",
          "inputs": [
